BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8788

# Feishu/Lark app credentials.
# By default the bridge can reuse Hermes credentials from ~/.hermes/.env.
BRIDGE_USE_HERMES_FEISHU_ENV=true
BRIDGE_HERMES_ENV_PATH=~/.hermes/.env
BRIDGE_FEISHU_APP_ID=
BRIDGE_FEISHU_APP_SECRET=
BRIDGE_FEISHU_VERIFICATION_TOKEN=
BRIDGE_FEISHU_ENCRYPT_KEY=
# Accepts https://open.feishu.cn, https://open.larksuite.com, feishu, or lark.
BRIDGE_FEISHU_DOMAIN=
# send = normal visible chat message; reply = Feishu threaded reply under the user message.
BRIDGE_FEISHU_DELIVERY_MODE=send
# Forward Codex local approval prompts to Feishu with one-time approve/deny codes.
BRIDGE_FEISHU_APPROVAL_ENABLED=true
BRIDGE_FEISHU_APPROVAL_TIMEOUT_SECONDS=180
BRIDGE_FEISHU_PROGRESS_SECONDS=0
# Optional live stream forwarding. Off by default because it can expose
# reasoning/tool-progress details into Feishu chat.
BRIDGE_FEISHU_STREAM_UPDATES_ENABLED=false
BRIDGE_FEISHU_SHOW_REASONING=false
BRIDGE_FEISHU_SHOW_HISTORY=false
BRIDGE_FEISHU_STREAM_ASSISTANT_DELTAS=false
BRIDGE_FEISHU_STREAM_FLUSH_SECONDS=2
BRIDGE_FEISHU_STREAM_MAX_CHARS=3500
# Optional Feishu -> Codex history seeding. Off by default because it copies
# recent Feishu chat content into the visible Codex thread.
BRIDGE_FEISHU_SEED_HISTORY_TO_CODEX=false
BRIDGE_FEISHU_HISTORY_MAX_MESSAGES=20
BRIDGE_FEISHU_HISTORY_LOOKBACK_SECONDS=86400
BRIDGE_FEISHU_HISTORY_MAX_CHARS=8000

# Codex integration.
BRIDGE_CODEX_BINARY=/Applications/Codex.app/Contents/Resources/codex
BRIDGE_CODEX_CWD=.
BRIDGE_CODEX_MODEL=gpt-5.5
BRIDGE_CODEX_REASONING_EFFORT=medium
BRIDGE_CODEX_STREAM_LIMIT_BYTES=16777216
BRIDGE_CODEX_LOAD_HISTORY_ON_START=true

# false = text-only codex exec path for smoke tests.
# true = real Codex app-server thread bridge; messages appear in Codex UI.
BRIDGE_CODEX_USE_APP_SERVER=false
BRIDGE_CODEX_APP_SOCKET=
BRIDGE_CODEX_THREAD_MAP_PATH=.codex-thread-map.json
BRIDGE_CODEX_FIXED_THREAD_ID=
BRIDGE_CODEX_APPROVAL_POLICY=on-request
BRIDGE_CODEX_SANDBOX=read-only
BRIDGE_CODEX_THREAD_NAME_PREFIX=Feishu

# true = don't send replies to Feishu, only process locally.
BRIDGE_DRY_RUN_REPLIES=true
BRIDGE_REPLY_PREFIX=
BRIDGE_MEDIA_DIR=feishu-media
BRIDGE_MAX_MEDIA_BYTES=26214400
BRIDGE_IMAGE_USE_EXEC_FALLBACK=true
# Leave blank to inherit BRIDGE_CODEX_MODEL / BRIDGE_CODEX_REASONING_EFFORT.
BRIDGE_IMAGE_CODEX_MODEL=
BRIDGE_IMAGE_CODEX_REASONING_EFFORT=
